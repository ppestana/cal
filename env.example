# ─── SAEIF PoC — variáveis de ambiente ───────────────────────────────────────

# NASA FIRMS Map Key (gratuita, registo em https://firms.modaps.eosdis.nasa.gov/api/)
# Sem esta chave, o sistema usa dados de demonstração para os focos FIRMS.
FIRMS_MAP_KEY=

# Intervalo de actualização dos dados FIRMS (minutos, default 30)
REFRESH_FIRMS_MIN=30

# Intervalo de actualização dos dados IPMA (minutos, default 60)
REFRESH_IPMA_MIN=60
